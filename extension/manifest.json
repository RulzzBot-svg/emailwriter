{
  "manifest_version": 3,
  "name": "ProDraft Email Polisher",
  "version": "1.4.0",
  "description": "Turn your messy thoughts into professional emails.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open ProDraft"
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://127.0.0.1/*",
    "https://emailwriter-zeta.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://mail.yahoo.com/*"
      ],
      "js": [
        "extension-config.js",
        "client-id.js",
        "theme.js",
        "prodraft-shared.js",
        "content-script.js"
      ],
      "css": [
        "content-script.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
