{
  "manifest_version": 2,
  "name": "ProDraft Email Polisher",
  "version": "1.2.0",
  "description": "Turn your messy thoughts into professional emails.",
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Open ProDraft"
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://127.0.0.1/*",
    "https://mail.google.com/*",
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://mail.yahoo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://mail.yahoo.com/*"
      ],
      "js": [
        "extension-config.js",
        "theme.js",
        "prodraft-shared.js",
        "content-script.js"
      ],
      "css": [
        "content-script.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
